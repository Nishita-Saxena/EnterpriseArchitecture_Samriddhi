---
import SearchBar from './SearchBar.astro';

const { currentSection = 'Home' } = Astro.props as {
  currentSection?: string;
};

const breadcrumb =
  currentSection === 'Home'
    ? 'Home'
    : `Home / ${currentSection}`;
---

<header class="header" aria-label="Portal header">
  <div class="identity">
    <p class="eyebrow">Enterprise Architecture Repository</p>
    <h1>Samriddhi Architecture Review Portal</h1>
  </div>

  <div class="context">
    <p class="section">{currentSection}</p>
    <p class="breadcrumb">{breadcrumb}</p>
  </div>

  <div class="actions">
    <SearchBar />

    <span class="status-badge">
      TOGAF Repository
    </span>
  </div>
</header>

<style>
  .header {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) auto auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #d6deea;
    background: #ffffff;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .identity {
    min-width: 0;
  }

  .eyebrow {
    margin: 0 0 0.3rem;
    color: #5f6c7b;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: #182230;
    font-size: 1.15rem;
    font-weight: 700;
  }

  .context {
    min-width: 0;
  }

  .section {
    margin: 0;
    color: #183153;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .breadcrumb {
    margin: 0.25rem 0 0;
    color: #667085;
    font-size: 0.85rem;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    border: 1px solid #b7c6db;
    background: #eef4fc;
    color: #183153;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
  }

  @media (max-width: 1200px) {
    .header {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .actions {
      width: 100%;
      flex-wrap: wrap;
    }
  }
  @media (max-width: 900px) {
  .header {
    padding-top: 4rem;
  }
}
</style>
