---
import SearchBar from './SearchBar.astro';

const { currentSection = 'Home' } = Astro.props as {
  currentSection?: string;
};

const breadcrumb =
  currentSection === 'Home'
    ? 'Architecture Repository'
    : `Architecture Repository / ${currentSection}`;
---

<header class="header" aria-label="Portal header">

  <div class="workspace">

    <div class="title-group">
      <h1>{currentSection}</h1>
      <p>{breadcrumb}</p>
    </div>

  </div>

  <div class="actions">
    <SearchBar />

    <span class="status-badge">
      EA
    </span>
  </div>

</header>

<style>
  .header {

    position: sticky;
    top: 0;
    z-index: 100;

    display: flex;
    justify-content: space-between;
    align-items: center;

    gap: 1.5rem;

    padding: 1rem 1.75rem;

    background:
      rgba(255,255,255,0.88);

    backdrop-filter: blur(16px);

    border-bottom:
      1px solid rgba(226,232,240,0.9);

    box-shadow:
      0 2px 12px rgba(15,23,42,0.04);
  }

  .workspace {
    min-width: 0;
    flex: 1;
  }

  .title-group {
    min-width: 0;
  }

  .title-group h1 {

    margin: 0;

    color: #0f172a;

    font-size: 1.45rem;

    font-weight: 700;

    line-height: 1.2;

    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .title-group p {

    margin: 0.35rem 0 0;

    color: #64748b;

    font-size: 0.85rem;

    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .actions {

    display: flex;
    align-items: center;

    gap: 1rem;

    flex-shrink: 0;
  }

  .status-badge {

    display: inline-flex;
    align-items: center;
    justify-content: center;

    padding: 0.55rem 0.95rem;

    border-radius: 999px;

    background: #eff6ff;

    border: 1px solid #bfdbfe;

    color: #1d4ed8;

    font-size: 0.78rem;

    font-weight: 700;

    white-space: nowrap;
  }

  @media (max-width: 1200px) {

    .header {
      flex-wrap: wrap;
      align-items: flex-start;
    }

    .actions {
      width: 100%;
    }
  }

  @media (max-width: 900px) {

    .header {

      position: relative;

      padding:
        1rem
        1rem
        1rem
        4.5rem;

      gap: 0.85rem;
    }

    .title-group h1 {
      font-size: 1.1rem;
    }

    .title-group p {
      font-size: 0.78rem;
    }

    .actions {
      width: 100%;
    }

    .status-badge {
      display: none;
    }
  }

  @media (max-width: 600px) {

    .title-group h1 {
      font-size: 1rem;
    }

    .title-group p {
      display: none;
    }
  }
</style>
