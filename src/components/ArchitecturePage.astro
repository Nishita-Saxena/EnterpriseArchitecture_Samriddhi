---

import MetadataBar from './MetadataBar.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import DiagramViewer from './DiagramViewer.astro';
import PreviousNextNavigation from './PreviousNextNavigation.astro';
import { getBreadcrumbSection, getNavigationDocumentByTitle } from '../lib/navigation';

const {
title,
category,
version,
status,
image,
route,
} = Astro.props as {
title: string;
category: string;
version: string;
status: string;
image?: string;
route?: string;
};

const section = getBreadcrumbSection(title, category);
const sectionRoute = getNavigationDocumentByTitle(title)?.section
? `/${getNavigationDocumentByTitle(title)!.section.toLowerCase().replace(/\s+/g, '-')}`
: undefined;
---

<section class="architecture-page" aria-label="Architecture document">
  <header class="title-block">
    <Breadcrumbs section={section} title={title} />
    <h1>{title}</h1>
  </header>

<MetadataBar
 category={category}
 version={version}
 status={status}
/>

{image ? ( <DiagramViewer
   image={image}
   title={title}
 />
) : null}

  <article class="content prose" aria-label="Markdown content">
    <slot />
  </article>

  <PreviousNextNavigation title={title} />
</section>

<style>
  .architecture-page {
    display: grid;
    gap: 1.5rem;
    max-width: 1200px;
    color: #182230;
  }

  .title-block {
    display: grid;
    gap: 0.5rem;
  }

  .title-block h1 {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: #182230;
  }

  .content {
    min-width: 0;
  }

  .prose {
    background: #ffffff;
    border: 1px solid #d6deea;
    border-radius: 12px;
    padding: 2rem;
    line-height: 1.8;
    font-size: 1rem;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4 {
    color: #182230;
    line-height: 1.3;
    font-weight: 700;
  }

  .prose h1 {
    font-size: 2rem;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .prose h2 {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .prose h3 {
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose h4 {
    font-size: 1.1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose p {
    margin-bottom: 1rem;
  }

  .prose ul,
  .prose ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.4rem;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .prose th,
  .prose td {
    border: 1px solid #d6deea;
    padding: 0.75rem;
    text-align: left;
    vertical-align: top;
  }

  .prose th {
    background: #f7f9fc;
    font-weight: 700;
  }

  .prose blockquote {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 4px solid #1e3a5f;
    background: #f8fafc;
    color: #475467;
  }

  .prose img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .prose code {
    background: #f4f6f8;
    padding: 0.15rem 0.35rem;
    border-radius: 4px;
    font-size: 0.95em;
  }

  .prose pre {
    overflow-x: auto;
    padding: 1rem;
    border-radius: 8px;
    background: #f4f6f8;
  }

  @media (max-width: 768px) {
    .prose {
      padding: 1.25rem;
    }

    .title-block h1 {
      font-size: 1.6rem;
    }
  }
  .content {
  min-width: 0;
  background: #ffffff;
  border: 1px solid #d6deea;
  border-radius: 12px;
  padding: 2rem;
}
.content :global(h2) {
  margin-top: 2rem;
  color: #183153;
}

.content :global(h3) {
  margin-top: 1.5rem;
  color: #183153;
}

.content :global(p) {
  line-height: 1.8;
}

.content :global(ul) {
  line-height: 1.8;
}

.content :global(table) {
  width: 100%;
  border-collapse: collapse;
}

.content :global(th),
.content :global(td) {
  border: 1px solid #d6deea;
  padding: 0.75rem;
}
</style>
