---
import MetadataBar from './MetadataBar.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import DiagramViewer from './DiagramViewer.astro';
import PreviousNextNavigation from './PreviousNextNavigation.astro';
import {
  getBreadcrumbSection,
  getNavigationDocumentByTitle
} from '../lib/navigation';

const {
  title,
  category,
  version,
  status,
  image,
  route,
} = Astro.props as {
  title: string;
  category: string;
  version: string;
  status: string;
  image?: string;
  route?: string;
};

const section = getBreadcrumbSection(
  title,
  category
);

const sectionRoute =
  getNavigationDocumentByTitle(title)?.section
    ? `/${getNavigationDocumentByTitle(title)!
        .section
        .toLowerCase()
        .replace(/\s+/g, '-')}`
    : undefined;
---

<section
  class="architecture-page"
  aria-label="Architecture document"
>

  <header class="title-block">

    <Breadcrumbs
      section={section}
      title={title}
    />

    <h1>{title}</h1>

  </header>

  <MetadataBar
    category={category}
    version={version}
    status={status}
  />

  {image ? (

    <div class="diagram-card">

      <DiagramViewer
        image={image}
        title={title}
      />

    </div>

  ) : null}

  <article
    class="content"
    aria-label="Markdown content"
  >
    <slot />
  </article>

  <PreviousNextNavigation
    title={title}
  />

</section>

<style>

.architecture-page {

  width: 100%;

  max-width: 1280px;

  display: flex;
  flex-direction: column;

  gap: 1.25rem;
}

/* ---------- TITLE AREA ---------- */

.title-block {

  display: flex;
  flex-direction: column;

  gap: .5rem;
}

.title-block h1 {

  margin: 0;

  color: #0f172a;

  font-size: 2.75rem;

  font-weight: 700;

  line-height: 1.1;

  letter-spacing: -0.02em;
}

/* ---------- DIAGRAM ---------- */

.diagram-card {

  background: #ffffff;

  border: 1px solid #e2e8f0;

  border-radius: 18px;

  overflow: hidden;

  box-shadow:
    0 2px 8px rgba(15,23,42,.03);
}

/* ---------- CONTENT ---------- */

.content {

  background: #ffffff;

  border: 1px solid #e2e8f0;

  border-radius: 18px;

  padding: 2rem;

  box-shadow:
    0 2px 8px rgba(15,23,42,.03);

  color: #1e293b;

  line-height: 1.8;

  font-size: 1rem;
}

/* ---------- TYPOGRAPHY ---------- */

.content :global(h1),
.content :global(h2),
.content :global(h3),
.content :global(h4) {

  color: #0f172a;

  font-weight: 700;

  line-height: 1.25;
}

.content :global(h2) {

  margin-top: 2.5rem;
  margin-bottom: 1rem;

  padding-bottom: .6rem;

  border-bottom:
    1px solid #e2e8f0;

  font-size: 1.65rem;
}

.content :global(h3) {

  margin-top: 2rem;
  margin-bottom: .75rem;

  font-size: 1.25rem;
}

.content :global(h4) {

  margin-top: 1.5rem;
  margin-bottom: .5rem;

  font-size: 1.05rem;
}

.content :global(p) {

  margin-bottom: 1rem;
}

.content :global(ul),
.content :global(ol) {

  padding-left: 1.5rem;

  margin-bottom: 1rem;
}

.content :global(li) {

  margin-bottom: .4rem;
}

/* ---------- TABLES ---------- */

.content {
  overflow-x: auto;
}

.content :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5rem 0;
  min-width: 700px;
}

.content :global(th),
.content :global(td) {
  border: 1px solid #e2e8f0;
  padding: .85rem;
  text-align: left;
  vertical-align: top;
}

.content :global(th) {
  background: #f8fafc;
  font-weight: 700;
}

@media (max-width: 768px) {

  .content :global(table) {
    min-width: 650px;
  }

  .content :global(th),
  .content :global(td) {
    padding: .65rem;
    font-size: .9rem;
  }
}

.content :global(.table-wrapper) {
  overflow-x: auto;
  margin: 1.5rem 0;
}

/* ---------- BLOCKQUOTE ---------- */

.content :global(blockquote) {

  margin: 1.5rem 0;

  padding: 1rem 1.25rem;

  border-left: 4px solid #2563eb;

  background: #f8fafc;

  color: #475569;
}

/* ---------- CODE ---------- */

.content :global(code) {

  background: #f1f5f9;

  padding:
    .15rem
    .35rem;

  border-radius: 4px;
}

.content :global(pre) {

  overflow-x: auto;

  padding: 1rem;

  border-radius: 12px;

  background: #f8fafc;
}

/* ---------- IMAGES ---------- */

.content :global(img) {

  max-width: 100%;

  height: auto;

  border-radius: 12px;
}

/* ---------- MOBILE ---------- */

@media (max-width: 768px) {

  .architecture-page {
    gap: 1rem;
  }

  .title-block h1 {

    font-size: 2rem;
  }

  .content {

    padding: 1.25rem;
  }

  .content :global(h2) {

    font-size: 1.4rem;
  }
}

</style>
