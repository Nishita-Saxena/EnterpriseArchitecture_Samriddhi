---
import { NAVIGATION_TREE } from '../lib/navigation';

const { activeRoute = '/' } = Astro.props as {
  activeRoute?: string;
};

function isActive(route: string) {
  return (
    activeRoute === route ||
    (route !== '/' && activeRoute.startsWith(route + '/'))
  );
}
---

<aside class="sidebar" aria-label="Architecture navigation">

  <div class="brand">
    <p class="eyebrow">Enterprise Architecture</p>
    <h2>Samriddhi</h2>
    <p class="subtitle">Architecture Review Portal</p>
  </div>

  <nav
    class="navigation"
    id="navigation-panel"
  >
    <ul class="tree">

      {NAVIGATION_TREE.map((section) => {
        const expanded =
          section.items?.some((item) =>
            isActive(item.route)
          ) ?? false;

        return (
          <li class="section-group">

            {section.items ? (

              <details open={expanded}>

                <summary>
                  {section.label}
                </summary>

                <ul class="section-items">

                  {section.items.map((item) => (

                    <li>

                      <a
                        href={item.route}
                        class:list={[
                          'item',
                          isActive(item.route) &&
                            'active',
                        ]}
                        aria-current={
                          isActive(item.route)
                            ? 'page'
                            : undefined
                        }
                      >
                        {item.title}
                      </a>

                    </li>

                  ))}

                </ul>

              </details>

            ) : (

              <a
                href={section.route}
                class:list={[
                  'root',
                  isActive(section.route) &&
                    'active',
                ]}
              >
                {section.label}
              </a>

            )}

          </li>
        );
      })}

    </ul>
  </nav>

  <div class="footer">
    <p>TOGAF Architecture Repository</p>
  </div>

</aside>

<script>
  window.addEventListener('load', () => {

    const navigation =
      document.getElementById(
        'navigation-panel'
      );

    if (!navigation) return;

    const savedPosition =
      sessionStorage.getItem(
        'sidebar-scroll'
      );

    if (savedPosition) {
      navigation.scrollTop =
        Number(savedPosition);
    }

    navigation.addEventListener(
      'scroll',
      () => {

        sessionStorage.setItem(
          'sidebar-scroll',
          String(navigation.scrollTop)
        );

      }
    );

  });
</script>

<style>

.sidebar {

  display: flex;
  flex-direction: column;

  width: 280px;
  min-height: 100vh;

  background: #ffffff;

  border-right:
    1px solid #e5e7eb;

  color: #0f172a;

  overflow: hidden;
}

.brand {

  padding:
    1.5rem
    1.5rem
    1.25rem;

  border-bottom:
    1px solid #f1f5f9;
}

.eyebrow {

  margin: 0;

  color: #64748b;

  font-size: 0.68rem;

  font-weight: 700;

  letter-spacing: .08em;

  text-transform: uppercase;
}

h2 {

  margin:
    .45rem 0 0;

  font-size: 1.35rem;

  font-weight: 700;

  line-height: 1.2;

  color: #0f172a;
}

.subtitle {

  margin:
    .3rem 0 0;

  color: #64748b;

  font-size: .88rem;
}

.navigation {

  flex: 1;

  overflow-y: auto;

  padding:
    .75rem;
}

.tree,
.tree ul {

  list-style: none;

  margin: 0;
  padding: 0;
}

.section-group {
  margin-bottom: .25rem;
}

details {
  margin: 0;
}

summary {

  list-style: none;

  display: flex;
  align-items: center;

  min-height: 40px;

  padding:
    .65rem
    .85rem;

  border-radius: 10px;

  cursor: pointer;

  color: #334155;

  font-size: .92rem;

  font-weight: 600;
}

summary::-webkit-details-marker {
  display: none;
}

summary:hover {
  background: #f8fafc;
}

.section-items {

  margin-top: .15rem;

  margin-left: .9rem;

  padding-left: .9rem;

  border-left:
    1px solid #e2e8f0;
}

.section-items li {
  margin: .1rem 0;
}

.item {

  display: block;

  padding:
    .55rem
    .75rem;

  border-radius: 8px;

  color: #475569;

  font-size: .9rem;

  text-decoration: none;
}

.item:hover {

  background: #f8fafc;

  color: #0f172a;
}

.item.active {

  background: #eff6ff;

  color: #2563eb;

  font-weight: 600;
}

.root {

  display: block;

  padding:
    .65rem
    .85rem;

  border-radius: 10px;

  color: #334155;

  font-size: .92rem;

  font-weight: 600;

  text-decoration: none;
}

.root:hover {
  background: #f8fafc;
}

.root.active {

  background: #eff6ff;

  color: #2563eb;
}

.footer {

  padding:
    1rem
    1.5rem;

  border-top:
    1px solid #f1f5f9;
}

.footer p {

  margin: 0;

  color: #94a3b8;

  font-size: .75rem;
}

.navigation::-webkit-scrollbar {
  width: 6px;
}

.navigation::-webkit-scrollbar-thumb {

  background: #dbe4ee;

  border-radius: 999px;
}

.navigation::-webkit-scrollbar-track {
  background: transparent;
}

@media (max-width: 900px) {

  .sidebar {
    width: 320px;
  }

  .brand {
    padding-top: 4.5rem;
  }
}

</style>
