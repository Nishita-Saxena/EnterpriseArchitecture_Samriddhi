---
import { NAVIGATION_DOCUMENTS } from '../lib/navigation';
---

<div class="search-wrapper">

  <div class="search-shell">

    <span class="search-icon">⌕</span>

    <input
      id="searchInput"
      type="text"
      placeholder="Search architecture artifacts..."
      autocomplete="off"
    />

    <span class="shortcut">
      ⌘K
    </span>

  </div>

  <div
    id="searchResults"
    class="results"
  ></div>

</div>

<script define:vars={{ docs: NAVIGATION_DOCUMENTS }}>

  const input =
    document.getElementById('searchInput');

  const results =
    document.getElementById('searchResults');

  input?.addEventListener('input', (event) => {

    const value =
      event.target.value
        .toLowerCase()
        .trim();

    if (!value) {

      results.innerHTML = '';

      results.classList.remove('visible');

      return;
    }

    const matches =
      docs.filter((doc) =>
        doc.title
          .toLowerCase()
          .includes(value)
      );

    if (!matches.length) {

      results.innerHTML = `
        <div class="empty">
          No matching architecture artifacts found
        </div>
      `;

      results.classList.add('visible');

      return;
    }

    results.innerHTML =
      matches
        .slice(0, 10)
        .map(
          (doc) => `
            <a
              href="${doc.route}"
              class="result"
            >
              <div class="result-main">
                <span class="title">
                  ${doc.title}
                </span>

                <span class="route">
                  ${doc.route}
                </span>
              </div>

              <span class="arrow">
                →
              </span>
            </a>
          `
        )
        .join('');

    results.classList.add('visible');
  });

  document.addEventListener('click', (event) => {

    if (
      !event.target.closest('.search-wrapper')
    ) {

      results.innerHTML = '';

      results.classList.remove('visible');
    }
  });
</script>

<style>

  .search-wrapper {

    position: relative;

    width: 440px;

    max-width: 100%;
  }

  .search-shell {

    display: flex;

    align-items: center;

    gap: 0.75rem;

    height: 48px;

    padding: 0 0.85rem;

    border:
      1px solid #dbe4f0;

    border-radius: 14px;

    background:
      rgba(255,255,255,0.92);

    backdrop-filter:
      blur(8px);

    box-shadow:
      0 2px 10px rgba(15,23,42,.04);

    transition:
      border-color .2s ease,
      box-shadow .2s ease;
  }

  .search-shell:focus-within {

    border-color: #2563eb;

    box-shadow:
      0 0 0 4px rgba(37,99,235,.12);
  }

  .search-icon {

    flex-shrink: 0;

    color: #64748b;

    font-size: 1rem;
  }

  #searchInput {

    flex: 1;

    border: none;

    outline: none;

    background: transparent;

    color: #0f172a;

    font-size: 0.92rem;

    min-width: 0;
  }

  #searchInput::placeholder {

    color: #94a3b8;
  }

  .shortcut {

    flex-shrink: 0;

    padding:
      0.18rem
      0.45rem;

    border-radius: 8px;

    background: #f8fafc;

    border:
      1px solid #e2e8f0;

    color: #64748b;

    font-size: 0.72rem;

    font-weight: 600;
  }

  .results {

    display: none;

    position: absolute;

    top: calc(100% + 10px);

    left: 0;

    width: 100%;

    background: white;

    border:
      1px solid #e2e8f0;

    border-radius: 18px;

    overflow: hidden;

    box-shadow:
      0 18px 40px rgba(15,23,42,.12);

    max-height: 420px;

    overflow-y: auto;

    z-index: 9999;
  }

  .results.visible {
    display: block;
  }

  .result {

    display: flex;

    justify-content: space-between;

    align-items: center;

    gap: 1rem;

    padding:
      1rem
      1.1rem;

    text-decoration: none;

    border-bottom:
      1px solid #eef2f7;
  }

  .result:last-child {
    border-bottom: none;
  }

  .result:hover {

    background:
      #f8fafc;
  }

  .result-main {
    min-width: 0;
  }

  .title {

    display: block;

    color: #0f172a;

    font-weight: 600;

    font-size: 0.92rem;
  }

  .route {

    display: block;

    margin-top: 0.3rem;

    color: #64748b;

    font-size: 0.75rem;

    overflow: hidden;

    text-overflow: ellipsis;

    white-space: nowrap;
  }

  .arrow {

    color: #94a3b8;

    font-size: 0.9rem;

    flex-shrink: 0;
  }

  .empty {

    padding: 1rem;

    color: #64748b;

    font-size: 0.9rem;
  }

  @media (max-width: 900px) {

    .search-wrapper {
      width: 100%;
    }

    .shortcut {
      display: none;
    }

    .search-shell {
      height: 46px;
    }

    #searchInput {
      font-size: 16px;
    }
  }

</style>