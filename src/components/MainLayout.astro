---
import Header from './Header.astro';
import Sidebar from './Sidebar.astro';

const {
  title = 'Samriddhi Architecture Review Portal',
  currentSection = 'Home',
  activeRoute = '/',
} = Astro.props as {
  title?: string;
  currentSection?: string;
  activeRoute?: string;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <style>
      :root {
        color-scheme: light;

        --background: #f4f7fb;
        --surface: #ffffff;

        --text: #182230;
        --muted: #667085;

        --border: #d6deea;

        --primary: #183153;
        --primary-soft: #eef4fc;

        --shadow:
          0 1px 2px rgba(16, 24, 40, 0.05),
          0 1px 3px rgba(16, 24, 40, 0.1);
      }

      * {
  box-sizing: border-box;
  transition:
    background-color 0.15s ease,
    color 0.15s ease,
    border-color 0.15s ease,
    box-shadow 0.15s ease,
    transform 0.15s ease;
}
  html {
  scroll-behavior: smooth;
}
      html,
      body {
        margin: 0;
        min-height: 100%;
      }

      body {
        margin: 0;
        font-family:
          Inter,
          Segoe UI,
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
      background: #eef2f7;
      color: #182230;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      }

      a {
        color: inherit;
      }

      .layout {
        display: grid;
        grid-template-columns: 320px minmax(0, 1fr);
        min-height: 100vh;
      }

      .sidebar-region {
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        overflow-x: hidden;
        background: var(--surface);
        border-right: 1px solid var(--border);
      }

      .main-column {
        display: grid;
        grid-template-rows: auto 1fr;
        min-width: 0;
      }

      .content {
        padding: 2rem;
        min-width: 0;
         max-width: 1600px;
      }

      .content > * {
        max-width: 1400px;
      }

      @media (max-width: 1100px) {
        .layout {
          grid-template-columns: 280px minmax(0, 1fr);
        }
      }

      @media (max-width: 900px) {
        .layout {
          grid-template-columns: 1fr;
        }

        .sidebar-region {
          position: static;
          height: auto;
        }

        .content {
          padding: 1rem;
        }
      }
      .mobile-menu-toggle {
  display: none;
}

@media (max-width: 900px) {

  .mobile-menu-toggle {
    display: block;
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 9999;

    padding: 0.75rem 1rem;

    border: 1px solid var(--border);
    border-radius: 10px;

    background: white;
    color: var(--primary);

    font-weight: 600;

    box-shadow: var(--shadow);
  }

  .sidebar-region {
    position: fixed;
    left: -340px;
    top: 0;

    width: 320px;
    height: 100vh;

    z-index: 9998;

    background: white;

    transition: left 0.25s ease;
  }

  .sidebar-region.mobile-open {
    left: 0;
  }

  .main-column {
    width: 100%;
  }
}
    </style>
  </head>

  <body>

    <button
      id="mobile-menu-toggle"
      class="mobile-menu-toggle"
      aria-label="Open navigation"
    >
      ☰ Menu
    </button>

    <div class="layout">
      <aside
        class="sidebar-region"
        id="sidebar-region"
      >
        <Sidebar activeRoute={activeRoute} />
      </aside>

      <div class="main-column">
        <Header currentSection={currentSection} />

        <main class="content">
          <slot />
        </main>
      </div>
    </div>
    <script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const sidebar = document.getElementById('sidebar-region');

  toggle?.addEventListener('click', () => {
    sidebar?.classList.toggle('mobile-open');
  });
</script>
  </body>
</html>
